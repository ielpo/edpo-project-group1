  <bpmn:process id="Process_0g7lwbb" isExecutable="true" camunda:historyTimeToLive="4">
    <bpmn:startEvent id="Event_0cgpadu" name="Start order process" camunda:formRef="form_1" camunda:formRefBinding="latest">
      <bpmn:outgoing>Flow_183sx42</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_09ap23g" messageRef="Message_1eaptk4" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_183sx42" sourceRef="Event_0cgpadu" targetRef="Task_VerifyOrder" />
    <bpmn:serviceTask id="Task_VerifyOrder" name="Reserve inventory" camunda:delegateExpression="${reserveInventoryDelegate}">
      <bpmn:incoming>Flow_183sx42</bpmn:incoming>
      <bpmn:outgoing>Flow_1c4cdub</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0bprnq2" name="Reservation successful?" default="Flow_1hn6wbk">
      <bpmn:incoming>Flow_1c4cdub</bpmn:incoming>
      <bpmn:outgoing>Flow_0jr2rv0</bpmn:outgoing>
      <bpmn:outgoing>Flow_1hn6wbk</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1c4cdub" sourceRef="Task_VerifyOrder" targetRef="Gateway_0bprnq2" />
    <bpmn:sequenceFlow id="Flow_0jr2rv0" name="Yes" sourceRef="Gateway_0bprnq2" targetRef="Task_SendManufactureCommand">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${inventoryReservationSuccess == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sendTask id="Task_SendManufactureCommand" name="Send order.manufacture.v1" camunda:delegateExpression="${publishManufactureOrderDelegate}">
      <bpmn:incoming>Flow_0jr2rv0</bpmn:incoming>
      <bpmn:outgoing>Flow_1hfmgaj</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_1hn6wbk" name="No" sourceRef="Gateway_0bprnq2" targetRef="Event_00lv4zj" />
    <bpmn:boundaryEvent id="Event_0sihvtw" name="Inventory service not available" attachedToRef="Task_VerifyOrder">
      <bpmn:outgoing>Flow_0egzzm6</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_14xt49u" errorRef="Error_0lddp1d" camunda:errorCodeVariable="inventoryReservationErrorCode" camunda:errorMessageVariable="inventoryReservationErrorMessage" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0egzzm6" sourceRef="Event_0sihvtw" targetRef="Event_0s0twye" />
    <bpmn:endEvent id="Event_00lv4zj" name="Send info.v1 missing inventory">
      <bpmn:incoming>Flow_1hn6wbk</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1hprxwm" camunda:delegateExpression="${publishInventoryReservationInfoDelegate}" />
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_0s0twye" name="Send error.v1 inventory unavailable">
      <bpmn:incoming>Flow_0egzzm6</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0m9pzxp" camunda:delegateExpression="${publishInventoryReservationErrorDelegate}" />
    </bpmn:endEvent>
    <bpmn:eventBasedGateway id="Gateway_1yfhskd">
      <bpmn:incoming>Flow_1hfmgaj</bpmn:incoming>
      <bpmn:outgoing>Flow_0a3n8r2</bpmn:outgoing>
      <bpmn:outgoing>Flow_0q7x5l1</bpmn:outgoing>
      <bpmn:outgoing>Flow_0r8m6v3</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="Flow_1hfmgaj" sourceRef="Task_SendManufactureCommand" targetRef="Gateway_1yfhskd" />
    <bpmn:sequenceFlow id="Flow_0a3n8r2" sourceRef="Gateway_1yfhskd" targetRef="Event_0v1comp" />
    <bpmn:intermediateCatchEvent id="Event_0v1comp" name="Wait for order.complete.v1">
      <bpmn:incoming>Flow_0a3n8r2</bpmn:incoming>
      <bpmn:outgoing>Flow_1x2m4k9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1m2v8fd" messageRef="Message_3c44enc" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1x2m4k9" sourceRef="Event_0v1comp" targetRef="Event_0doneok" />
    <bpmn:sequenceFlow id="Flow_0q7x5l1" sourceRef="Gateway_1yfhskd" targetRef="Event_0tm3min" />
    <bpmn:intermediateCatchEvent id="Event_0tm3min" name="Wait 3 minutes">
      <bpmn:incoming>Flow_0q7x5l1</bpmn:incoming>
      <bpmn:outgoing>Flow_0h3u7p5</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0f3m9n1">
        <bpmn:timeDuration>PT3M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_0h3u7p5" sourceRef="Event_0tm3min" targetRef="Event_0to3min" />
    <bpmn:endEvent id="Event_0to3min" name="Send error.v1&#10;manufacturing timed out">
      <bpmn:incoming>Flow_0h3u7p5</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_12nhj0r" camunda:delegateExpression="${publishManufacturingTimeoutErrorDelegate}" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0r8m6v3" sourceRef="Gateway_1yfhskd" targetRef="Event_1errorfb" />
    <bpmn:intermediateCatchEvent id="Event_1errorfb" name="Wait for&#10;error.v1">
      <bpmn:incoming>Flow_0r8m6v3</bpmn:incoming>
      <bpmn:outgoing>Flow_1v4m7c2</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1errorfb" messageRef="Message_1errorfb" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1v4m7c2" sourceRef="Event_1errorfb" targetRef="Event_1errordone" />
    <bpmn:endEvent id="Event_1errordone" name="Send error.v1&#10;manufacturing error">
      <bpmn:incoming>Flow_1v4m7c2</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0factoryerr" camunda:delegateExpression="${publishFactoryErrorDelegate}" />
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_0doneok" name="Send info.v1 manufcaturing success">
      <bpmn:incoming>Flow_1x2m4k9</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0c7fsz6" camunda:delegateExpression="${publishFactoryInfoDelegate}" />
    </bpmn:endEvent>
    <bpmn:textAnnotation id="TextAnnotation_0o1uhio">
      <bpmn:text>we could add retries</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0hxxtul" associationDirection="None" sourceRef="TextAnnotation_0o1uhio" targetRef="Task_VerifyOrder" />
